---
interface Props {
  href?: string;
  class?: string;
  [key: string]: unknown;
}

const { href, class: className, ...rest } = Astro.props;

const base = [
  'bg-surface border border-stroke rounded-2xl backdrop-blur-md',
  'transition-all duration-300 ease-out hover:-translate-y-1 hover:shadow-lg hover:shadow-black/30',
];
---

{
  href ? (
    <a href={href} class:list={[...base, className]} {...rest}>
      <slot />
    </a>
  ) : (
    <div class:list={[...base, className]} {...rest}>
      <slot />
    </div>
  )
}

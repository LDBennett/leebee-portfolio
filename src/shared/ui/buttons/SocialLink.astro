---
interface Props {
  href: string;
  label: string;
  external?: boolean;
}

const { href, label, external = true } = Astro.props;
---

<a
  href={href}
  aria-label={label}
  target={external ? '_blank' : undefined}
  rel={external ? 'noopener noreferrer' : undefined}
  class="text-muted hover:text-highlight transition-colors duration-200"
>
  <slot />
</a>

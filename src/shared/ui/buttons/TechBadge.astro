---
interface Props {
  label: string;
  tint?: string;
}

const { label, tint } = Astro.props;
---

<span
  class:list={[
    'border text-xs font-mono px-2.5 py-1 rounded-full transition-all duration-200 cursor-default hover:-translate-y-0.5 hover:scale-105 hover:shadow-sm',
    tint ?? 'bg-surface border-stroke-subtle text-secondary',
  ]}
>
  {label}
</span>

---
interface Props {
  backHref: string;
  backLabel: string;
}

const { backHref, backLabel } = Astro.props;
---

<div class="min-h-screen px-8 py-16">
  <div class="mx-auto max-w-3xl">
    <a
      href={backHref}
      class="text-muted/60 hover:text-accent mb-10 inline-flex items-center gap-2 font-mono text-xs tracking-widest uppercase transition-colors duration-200"
    >
      ← {backLabel}
    </a>

    <div class="mb-4">
      <slot name="header" />
    </div>

    <div class="note-prose">
      <slot />
    </div>

    <div class="border-stroke-subtle mt-12 border-t pt-8">
      <slot name="footer" />
    </div>
  </div>
</div>

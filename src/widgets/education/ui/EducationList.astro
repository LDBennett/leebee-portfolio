---
import { Kicker } from '@shared/ui';
import { getEducation } from '@entities/education';

const entries = await getEducation();
---

<section class="px-8 pb-16">
  <div class="mx-auto max-w-4xl">
    <h2 class="text-primary mb-8 text-3xl font-bold">Education</h2>

    <div class="flex flex-col gap-8">
      {
        entries.map((entry) => (
          <div>
            <div class="flex items-baseline justify-between gap-4">
              <p class="text-primary font-semibold">{entry.data.institution}</p>
              <span class="text-muted shrink-0 font-mono text-xs">
                {entry.data.startYear}–{entry.data.endYear}
              </span>
            </div>
            <p class="text-secondary mt-0.5 text-sm">
              {entry.data.degree}, {entry.data.field}
            </p>
            {(entry.data.honors || entry.data.minor) && (
              <p class="text-muted mt-0.5 text-xs">
                {[entry.data.honors, entry.data.minor && `Minor in ${entry.data.minor}`]
                  .filter(Boolean)
                  .join(' · ')}
              </p>
            )}
            {entry.data.focus && <p class="text-muted/60 mt-0.5 text-xs">{entry.data.focus}</p>}
            {entry.data.courses && entry.data.courses.length > 0 && (
              <ul class="mt-2 flex flex-col gap-0.5">
                {entry.data.courses.map((course) => (
                  <li class="text-muted/60 font-mono text-xs">{course}</li>
                ))}
              </ul>
            )}
          </div>
        ))
      }
    </div>
  </div>
</section>

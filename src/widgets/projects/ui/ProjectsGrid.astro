---
import { getProjects, ProjectCard } from '@entities/project';

const projects = await getProjects();
const sorted = projects.sort((a, b) => {
  if (a.data.featured && !b.data.featured) return -1;
  if (!a.data.featured && b.data.featured) return 1;
  return b.data.startDate.getTime() - a.data.startDate.getTime();
});
---

<section id="projects" class="max-w-4xl mx-auto px-8 py-16">
  <p class="text-blue-400 text-xs font-mono uppercase tracking-widest mb-2">Work</p>
  <h2 class="text-slate-50 text-3xl font-bold mb-8">Projects</h2>

  <div class="grid grid-cols-1 md:grid-cols-2 auto-rows-[minmax(180px,auto)] gap-4">
    {sorted.map((project) => <ProjectCard project={project} />)}
  </div>
</section>

<script>
  import '@shared/ui/scripts/scrollReveal.ts';
</script>

---
import { Kicker } from '@shared/ui';
import { ProjectCard, getProjects } from '@entities/project';
import { getProjectNoteSlugs } from '@entities/projectNote';

const projects = await getProjects();
const noteSlugs = await getProjectNoteSlugs();
---

<section id="projects" class="mx-auto max-w-4xl px-8 py-16">
  <Kicker color="text-warm" as="p" class="mb-2">Work</Kicker>
  <h2 class="text-primary mb-8 text-3xl font-bold">Projects</h2>

  <div class="grid auto-rows-[minmax(180px,auto)] grid-cols-1 gap-4 md:grid-cols-2">
    {
      projects.map((project) => (
        <ProjectCard project={project} hasNotes={noteSlugs.has(project.id)} />
      ))
    }
  </div>
</section>

<script>
  import '@shared/ui/scripts/scrollReveal.ts';
</script>

---
import { Icon } from 'astro-icon/components';
import { SocialLink } from '@shared/ui';
---

<section class="flex min-h-screen items-center justify-center p-8">
  <div
    class="grid w-full max-w-4xl auto-rows-[minmax(180px,auto)] grid-cols-1 gap-4 md:grid-cols-2"
  >
    <!-- Name / bio card -->
    <div
      data-hero-card
      data-tilt="4"
      class="flex flex-col justify-between rounded-2xl border border-stroke bg-surface p-8 backdrop-blur-md transition-all duration-300 ease-out hover:-translate-y-1 hover:shadow-lg hover:shadow-black/30 md:col-span-2"
    >
      <div>
        <p class="mb-3 font-mono text-xs tracking-widest text-accent uppercase">hello, I'm</p>
        <h1 data-typewriter data-text="Lee Bennett" class="text-5xl font-bold tracking-tight text-primary"></h1>
        <p class="mt-2 text-lg text-secondary">Full-Stack Engineer</p>
        <p class="mt-4 max-w-lg text-sm leading-relaxed text-muted">
          Over eight years of experience building content for the web
        </p>
      </div>

      <div class="mt-8 flex items-center justify-between border-t border-stroke-subtle pt-6">
        <div class="flex items-center gap-1.5 font-mono text-xs text-muted">
          <Icon name="lucide:map-pin" size={12} aria-hidden="true" />
          Pittsburgh, PA
        </div>

        <div class="flex items-center gap-5">
          <SocialLink href="https://github.com/LDBennett" label="GitHub">
            <Icon name="simple-icons:github" size={20} aria-hidden="true" />
          </SocialLink>

          <SocialLink href="https://linkedin.com/in/LDBennett" label="LinkedIn">
            <Icon name="simple-icons:linkedin" size={20} aria-hidden="true" />
          </SocialLink>

          <SocialLink href="mailto:ldbennett@gmail.com" label="Email" external={false}>
            <Icon name="lucide:mail" size={20} aria-hidden="true" />
          </SocialLink>
        </div>
      </div>
    </div>

    <!-- Projects nav card -->
    <a
      data-hero-card
      data-tilt
      href="#projects"
      class="flex flex-col justify-between rounded-2xl border border-stroke bg-surface p-6 backdrop-blur-md transition-all duration-300 ease-out hover:-translate-y-1 hover:shadow-lg hover:shadow-black/30"
    >
      <span class="font-mono text-xs tracking-widest text-highlight uppercase">Work</span>
      <div>
        <h2 class="text-xl font-semibold text-primary">Projects</h2>
        <p class="mt-1 text-sm text-secondary">My Most Recent Work</p>
      </div>
    </a>

    <!-- Resume nav card -->
    <a
      data-hero-card
      data-tilt
      href="#resume"
      class="flex flex-col justify-between rounded-2xl border border-stroke bg-surface p-6 backdrop-blur-md transition-all duration-300 ease-out hover:-translate-y-1 hover:shadow-lg hover:shadow-black/30"
    >
      <span class="font-mono text-xs tracking-widest text-accent uppercase">Experience</span>
      <div>
        <h2 class="text-xl font-semibold text-primary">Resume</h2>
        <p class="mt-1 text-sm text-secondary">Work history & skills</p>
      </div>
    </a>
  </div>
</section>

<script>
  import '../scripts/heroAnimation.ts';
</script>
<script>
  import '../scripts/typewriter.ts';
</script>

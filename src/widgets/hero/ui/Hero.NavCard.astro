---
import { Icon } from 'astro-icon/components';

interface Props {
  href: string;
  label: string;
  labelColor: string;
  title: string;
  subtitle: string;
}

const { href, label, labelColor, title, subtitle } = Astro.props;
---

<a
  data-hero-card
  data-tilt
  href={href}
  class="group border-stroke bg-surface flex flex-col justify-between rounded-2xl border p-6 backdrop-blur-md transition-all duration-300 ease-out hover:-translate-y-1 hover:shadow-lg hover:shadow-black/30"
>
  <span class:list={[labelColor, 'font-mono text-xs tracking-widest uppercase']}>{label}</span>
  <div class="flex items-end justify-between">
    <div>
      <h2 class="text-primary text-xl font-semibold">{title}</h2>
      <p class="text-secondary mt-1 text-sm">{subtitle}</p>
    </div>
    <Icon
      name="lucide:arrow-down"
      size={18}
      class="text-muted/40 mb-0.5 shrink-0 transition-transform duration-300 group-hover:translate-y-1"
      aria-hidden="true"
    />
  </div>
</a>

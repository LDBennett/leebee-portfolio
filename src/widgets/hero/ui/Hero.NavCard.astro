---
import { Icon } from 'astro-icon/components';
import { Card, Kicker } from '@shared/ui';

interface Props {
  href: string;
  label: string;
  labelColor: string;
  title: string;
  subtitle: string;
}

const { href, label, labelColor, title, subtitle } = Astro.props;
---

<Card
  href={href}
  data-hero-card
  data-tilt
  class="group flex flex-col justify-between p-6"
>
  <Kicker color={labelColor}>{label}</Kicker>
  <div class="flex items-end justify-between">
    <div>
      <h2 class="text-primary text-xl font-semibold">{title}</h2>
      <p class="text-secondary mt-1 text-sm">{subtitle}</p>
    </div>
    <Icon
      name="lucide:arrow-down"
      size={18}
      class="text-muted/40 mb-0.5 shrink-0 transition-transform duration-300 group-hover:translate-y-1"
      aria-hidden="true"
    />
  </div>
</Card>

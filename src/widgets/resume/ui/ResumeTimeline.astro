---
import { ResumeEntry, getResumeEntries, formatDate } from '@entities/resume';
import { getResumeNoteSlugs } from '@entities/resumeNote';

const entries = await getResumeEntries();
const noteSlugs = await getResumeNoteSlugs();
---

<section id="resume" class="mx-auto max-w-4xl px-8 py-16">
  <p class="text-accent mb-2 font-mono text-xs tracking-widest uppercase">Career</p>
  <h2 class="text-primary mb-10 text-3xl font-bold">Experience</h2>

  <div>
    {
      entries.map((entry) => (
        <div class="group flex gap-0" data-scroll-reveal>
          <div class="w-28 shrink-0 pt-1.5 pr-6 text-right">
            <span class="text-muted group-hover:text-secondary font-mono text-xs transition-colors duration-300">
              {formatDate(entry.data.startDate)}
            </span>
            <span class="text-muted/30 group-hover:text-secondary/50 block font-mono text-xs transition-colors duration-300">
              –
            </span>
            <span class="text-muted group-hover:text-secondary block font-mono text-xs transition-colors duration-300">
              {entry.data.endDate ? formatDate(entry.data.endDate) : 'Present'}
            </span>
          </div>

          <div class="border-stroke relative flex-1 border-l pb-12 pl-8">
            <div class="bg-highlight border-canvas absolute top-1.5 -left-1.25 h-2.5 w-2.5 rounded-full border-2 transition-all duration-400 ease-out group-hover:-left-0.5 group-hover:h-full group-hover:w-1 group-hover:border-0" />
            <div class="origin-top-left transition-all duration-300 ease-out group-hover:translate-x-3 group-hover:scale-[1.02]">
              <ResumeEntry entry={entry} hasNotes={noteSlugs.has(entry.id)} />
            </div>
          </div>
        </div>
      ))
    }
  </div>
</section>

<script>
  import '@shared/ui/scripts/scrollReveal.ts';
</script>

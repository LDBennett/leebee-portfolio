---
import { Kicker } from '@shared/ui';
import { ResumeEntry, getResumeEntries, formatDate } from '@entities/resume';
import { getResumeNoteSlugs } from '@entities/resumeNote';

const entries = await getResumeEntries();
const noteSlugs = await getResumeNoteSlugs();
---

<section id="resume" class="mx-auto max-w-4xl px-8 py-16">
  <Kicker color="text-accent" as="p" class="mb-2">Career</Kicker>
  <h2 class="text-primary mb-10 text-3xl font-bold">Experience</h2>

  <div>
    {
      entries.map((entry) => (
        <div class="group flex gap-0" data-scroll-reveal>
          {/* Date column — desktop only */}
          <div class="hidden w-28 shrink-0 pt-1.5 pr-6 text-right sm:block">
            <span class="text-muted font-mono text-xs transition-colors duration-300 group-hover:text-secondary">
              {entry.data.endDate ? formatDate(entry.data.endDate) : 'Present'}
            </span>
            <span class="text-muted/30 block font-mono text-xs transition-colors duration-300 group-hover:text-secondary/50">
              –
            </span>
            <span class="text-muted block font-mono text-xs transition-colors duration-300 group-hover:text-secondary">
              {formatDate(entry.data.startDate)}
            </span>
          </div>

          <div class="border-stroke relative flex-1 border-l pb-10 pl-6 sm:pb-12 sm:pl-8">
            <div class="bg-highlight border-canvas absolute top-1.5 -left-1.25 h-2.5 w-2.5 rounded-full border-2 transition-all duration-400 ease-out sm:group-hover:-left-0.5 sm:group-hover:h-3/4 sm:group-hover:w-1 sm:group-hover:border-0" />

            {/* Mobile date — single line, hidden on desktop */}
            <div class="mb-2 sm:hidden">
              <span class="text-muted font-mono text-xs">
                {formatDate(entry.data.startDate)} –{' '}
                {entry.data.endDate ? formatDate(entry.data.endDate) : 'Present'}
              </span>
            </div>

            <div class="origin-top-left transition-all duration-300 ease-out sm:group-hover:translate-x-3 sm:group-hover:scale-[1.02]">
              <ResumeEntry entry={entry} hasNotes={noteSlugs.has(entry.id)} />
            </div>
          </div>
        </div>
      ))
    }
  </div>
</section>

<script>
  import '@shared/ui/scripts/scrollReveal.ts';
</script>

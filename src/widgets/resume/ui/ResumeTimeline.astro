---
import { ResumeEntry, getResumeEntries, formatDate } from '@entities/resume';

const entries = await getResumeEntries();
---

<section id="resume" class="mx-auto max-w-4xl px-8 py-16">
  <p class="text-accent mb-2 font-mono text-xs tracking-widest uppercase">Career</p>
  <h2 class="text-primary mb-10 text-3xl font-bold">Experience</h2>

  <div>
    {
      entries.map((entry) => (
        <div class="flex gap-0" data-scroll-reveal>
          <div class="w-28 shrink-0 pt-1.5 pr-6 text-right">
            <span class="text-muted font-mono text-xs">{formatDate(entry.data.startDate)}</span>
            <span class="text-muted/30 block font-mono text-xs">–</span>
            <span class="text-muted block font-mono text-xs">
              {entry.data.endDate ? formatDate(entry.data.endDate) : 'Present'}
            </span>
          </div>

          <div class="border-stroke relative flex-1 border-l pb-12 pl-8">
            <div class="bg-highlight border-canvas absolute top-1.5 -left-1.25 h-2.5 w-2.5 rounded-full border-2" />
            <ResumeEntry entry={entry} />
          </div>
        </div>
      ))
    }
  </div>
</section>

<script>
  import '@shared/ui/scripts/scrollReveal.ts';
</script>

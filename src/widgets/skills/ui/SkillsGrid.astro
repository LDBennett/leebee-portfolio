---
import { Card, Kicker, TechBadge } from '@shared/ui';
import { skillCategories } from '../api/skills';
import { getBadgeTint } from '../utils/badgeTint';

const colSpanClass: Record<number, string> = {
  1: '',
  2: 'md:col-span-2',
  3: 'md:col-span-3',
};
---

<section id="skills" class="px-8 py-16">
  <div class="mx-auto max-w-4xl">
    <Kicker color="text-highlight" as="p" class="mb-2">Foundation</Kicker>
    <h2 class="text-primary mb-8 text-3xl font-bold">Skills & Tech</h2>

    <div class="grid auto-rows-[minmax(160px,auto)] grid-cols-1 gap-4 md:grid-cols-3">
      {
        skillCategories.map((category) => (
          <Card
            data-scroll-reveal
            data-tilt
            class:list={['flex flex-col gap-4 p-6', colSpanClass[category.colSpan ?? 1]]}
          >
            <Kicker color={category.accent}>{category.label}</Kicker>
            <div class="flex flex-wrap gap-2 [&:has(>_span:hover)_>_span:not(:hover)]:opacity-30">
              {category.skills.map((skill) => (
                <TechBadge label={skill} tint={getBadgeTint(category.color)} />
              ))}
            </div>
          </Card>
        ))
      }
    </div>
  </div>
</section>

<script>
  import '@shared/ui/scripts/scrollReveal.ts';
</script>

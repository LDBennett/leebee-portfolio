---
import type { ResumeEntry } from '../types/index';

interface Props {
  entry: ResumeEntry;
}

const { entry } = Astro.props;

const visibleTags = entry.data.tags.slice(0, 3);
const overflowCount = entry.data.tags.length - 3;
---

<div>
  <h3 class="text-primary font-semibold">{entry.data.role}</h3>
  <p class="text-secondary text-sm">{entry.data.company}</p>
  {
    entry.data.description && (
      <p class="text-muted mt-1.5 text-sm leading-relaxed">{entry.data.description}</p>
    )
  }
  <div class="mt-3 flex flex-wrap gap-1.5">
    {
      visibleTags.map((tag) => (
        <span class="bg-surface-subtle border-stroke-subtle text-muted rounded border px-2 py-0.5 font-mono text-xs">
          {tag}
        </span>
      ))
    }
    {
      overflowCount > 0 && (
        <span class="text-muted/40 px-1 font-mono text-xs">+{overflowCount}</span>
      )
    }
  </div>
</div>

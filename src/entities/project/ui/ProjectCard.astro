---
import type { CollectionEntry } from 'astro:content';
import { TechBadge } from '@shared/ui';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
---

<div
  data-scroll-reveal
  data-tilt
  class="bg-white/10 backdrop-blur-md border border-white/15 rounded-2xl p-6 flex flex-col justify-between transition-all duration-300 ease-out hover:-translate-y-1 hover:shadow-lg hover:shadow-black/30"
>
  <div>
    <div class="flex items-center justify-between">
      <span class="text-emerald-400 text-xs font-mono uppercase tracking-widest"
        >{project.data.type ?? 'Project'}</span
      >
      <span class="text-blue-400/50 text-xs font-mono">
        {project.data.startDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
      </span>
    </div>
    <h3 class="text-slate-50 text-xl font-semibold mt-2">{project.data.title}</h3>
    <p class="text-blue-200 text-sm mt-2 leading-relaxed">{project.data.description}</p>

    {project.data.note && <p class="mt-2 text-xs italic text-blue-400/50">{project.data.note}</p>}

    {
      project.data.highlights && project.data.highlights.length > 0 && (
        <ul class="mt-4 space-y-1.5">
          {project.data.highlights.map((point) => (
            <li class="flex items-start gap-2 text-blue-300/80 text-xs leading-relaxed">
              <span class="text-emerald-400 mt-0.5 shrink-0">→</span>
              {point}
            </li>
          ))}
        </ul>
      )
    }
  </div>

  <div class="mt-6 pt-4 border-t border-white/10">
    <div class="flex flex-wrap gap-1.5 mb-4">
      {project.data.tags.map((tag) => <TechBadge label={tag} />)}
    </div>

    <div class="flex items-center gap-4">
      {
        project.data.liveUrl && (
          <a
            href={project.data.liveUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="text-blue-400 text-xs font-mono hover:text-emerald-400 transition-colors duration-200"
          >
            → {new URL(project.data.liveUrl).hostname}
          </a>
        )
      }
      {
        project.data.repoUrl && (
          <a
            href={project.data.repoUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="text-blue-400/60 text-xs font-mono hover:text-emerald-400 transition-colors duration-200"
          >
            → github
          </a>
        )
      }
    </div>
  </div>
</div>

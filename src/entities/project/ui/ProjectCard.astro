---
import { Icon } from 'astro-icon/components';
import type { Project } from '../types/index';

interface Props {
  project: Project;
  hasNotes: boolean;
}

const { project, hasNotes } = Astro.props;

const primaryUrl = hasNotes
  ? `/projects/${project.id}`
  : (project.data.liveUrl ?? project.data.repoUrl ?? null);
---

<div
  data-scroll-reveal
  data-tilt
  class="bg-surface border-stroke group relative flex flex-col justify-between rounded-2xl border p-6 backdrop-blur-md transition-all duration-300 ease-out hover:-translate-y-1 hover:shadow-lg hover:shadow-black/30"
>
  <!-- Card-level overlay link — sits at z-0 so inner links stay clickable -->
  {
    primaryUrl && (
      <a
        href={primaryUrl}
        class="absolute inset-0 z-0 rounded-2xl"
        aria-label={project.data.title}
        {...(primaryUrl.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
      />
    )
  }

  <div class="relative z-10">
    <div class="flex items-center justify-between">
      <span class="text-highlight font-mono text-xs tracking-widest uppercase">
        {project.data.type ?? 'Project'}
      </span>
      <span class="text-muted font-mono text-xs">
        {project.data.startDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
      </span>
    </div>

    <!-- Title row with eye preview -->
    <div class="mt-2 flex items-start gap-3">
      <h3 class="text-primary min-w-0 flex-1 text-xl font-semibold">{project.data.title}</h3>

      <div class="relative shrink-0" data-preview-wrapper>
        <button
          type="button"
          aria-label="Preview screenshot"
          class="text-muted/40 hover:text-highlight focus:text-highlight flex items-center rounded transition-colors duration-200 focus:outline-none"
          data-preview-btn
        >
          <Icon name="lucide:eye" size={18} aria-hidden="true" />
        </button>

        <div
          data-preview-panel
          class="pointer-events-none absolute right-0 top-full z-50 mt-2 w-64 translate-y-1 opacity-0 transition-all duration-200"
        >
          <div class="border-stroke overflow-hidden rounded-xl border shadow-2xl shadow-black/60">
            {project.data.previewImage ? (
              <img
                src={project.data.previewImage}
                alt={`${project.data.title} preview`}
                class="aspect-video w-full object-cover object-top"
                loading="lazy"
              />
            ) : (
              <div class="bg-canvas/90 flex aspect-video items-center justify-center">
                <div class="text-center">
                  <Icon name="lucide:image" size={24} class="text-accent/20 mx-auto mb-2" aria-hidden="true" />
                  <span class="text-muted/40 font-mono text-xs">screenshot coming soon</span>
                </div>
              </div>
            )}
          </div>
          <div class="text-muted/40 mt-1.5 text-right font-mono text-xs">{project.data.title}</div>
        </div>
      </div>
    </div>

    <p class="text-body mt-2 text-sm leading-relaxed">{project.data.description}</p>
    {project.data.note && <p class="text-muted/70 mt-2 text-xs italic">{project.data.note}</p>}
  </div>

  <!-- Bottom row — always direct external links -->
  <div class="border-stroke-subtle relative z-10 mt-6 flex items-center gap-3 border-t pt-4">
    {
      project.data.repoUrl && (
        <a
          href={project.data.repoUrl}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub repository"
          class="card-link-underline text-muted/50 hover:text-highlight shrink-0 transition-colors duration-200"
          data-bottom-link
        >
          <Icon name="simple-icons:github" size={15} aria-hidden="true" />
        </a>
      )
    }
    {
      project.data.liveUrl && (
        <a
          href={project.data.liveUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="card-link-underline card-link-underline-d1 text-muted/50 hover:text-highlight font-mono text-xs transition-colors duration-200"
          data-bottom-link
        >
          {new URL(project.data.liveUrl).hostname}
        </a>
      )
    }

    {
      hasNotes && primaryUrl && (
        <a
          href={primaryUrl}
          class="card-link-underline card-link-underline-d2 text-muted/50 hover:text-highlight ml-auto font-mono text-xs transition-colors duration-200"
          data-bottom-link
        >
          deep dive →
        </a>
      )
    }
  </div>
</div>

<script>
  document.querySelectorAll('[data-preview-wrapper]').forEach((wrapper) => {
    const btn = wrapper.querySelector('[data-preview-btn]') as HTMLElement | null;
    const panel = wrapper.querySelector('[data-preview-panel]') as HTMLElement | null;
    const card = wrapper.closest('[data-scroll-reveal]') as HTMLElement | null;
    if (!btn || !panel || !card) return;

    const show = () => {
      panel.classList.remove('opacity-0', 'translate-y-1', 'pointer-events-none');
      panel.classList.add('opacity-100', 'translate-y-0', 'pointer-events-auto');
      card.style.zIndex = '50';
    };
    const hide = () => {
      panel.classList.add('opacity-0', 'translate-y-1', 'pointer-events-none');
      panel.classList.remove('opacity-100', 'translate-y-0', 'pointer-events-auto');
      card.style.zIndex = '';
    };

    wrapper.addEventListener('mouseenter', show);
    wrapper.addEventListener('mouseleave', hide);
    wrapper.addEventListener('focusin', show);
    wrapper.addEventListener('focusout', (e) => {
      if (!wrapper.contains((e as FocusEvent).relatedTarget as Node)) hide();
    });

    btn.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
    });
  });

  document.querySelectorAll('[data-bottom-link]').forEach((el) => {
    el.addEventListener('click', (e) => e.stopPropagation());
  });
</script>

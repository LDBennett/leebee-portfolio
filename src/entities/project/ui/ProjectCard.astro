---
import { Icon } from 'astro-icon/components';
import { Card, Kicker } from '@shared/ui';
import type { Project } from '../types/index';

interface Props {
  project: Project;
  hasNotes: boolean;
}

const { project, hasNotes } = Astro.props;

const primaryUrl = hasNotes ? `/projects/${project.id}` : null;

const statusColors: Record<string, string> = {
  'In Progress': 'text-warm border-warm/25 bg-warm/5',
  'Coming Soon': 'text-warm border-warm/25 bg-warm/5',
  Active: 'text-highlight border-highlight/25 bg-highlight/5',
  Completed: 'text-highlight border-highlight/25 bg-highlight/5',
  Published: 'text-accent border-accent/25 bg-accent/5',
};
---

<Card data-scroll-reveal data-tilt class="group flex flex-col justify-between p-6">
  <div class="relative z-10">
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-2">
        <Kicker color="text-highlight">{project.data.type ?? 'Project'}</Kicker>
        {
          project.data.status && (
            <span
              class:list={[
                'rounded border px-1.5 py-0.5 font-mono text-[9px] font-semibold tracking-wider uppercase',
                statusColors[project.data.status] || 'text-muted border-stroke bg-surface-subtle',
              ]}
            >
              {project.data.status}
            </span>
          )
        }
      </div>
      <span class="text-muted font-mono text-xs">
        {project.data.startDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
      </span>
    </div>

    {/* Title row with integrated action icons */}
    <div class="mt-2 flex items-start justify-between gap-4">
      <h3 class="text-primary text-xl font-semibold">{project.data.title}</h3>

      <div class="flex shrink-0 items-center gap-3">
        {
          project.data.repoUrl && (
            <a
              href={project.data.repoUrl}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="GitHub repository"
              class="text-muted/60 group-hover:text-highlight/50 hover:text-highlight -m-2 flex items-center justify-center p-2 transition-all duration-200 hover:-translate-y-0.5 hover:scale-110 active:scale-95"
            >
              <Icon name="simple-icons:github" size={16} aria-hidden="true" />
            </a>
          )
        }
        {
          project.data.liveUrl && (
            <a
              href={project.data.liveUrl}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Visit live site"
              class="text-muted/60 group-hover:text-highlight/50 hover:text-highlight -m-2 flex items-center justify-center p-2 transition-all duration-200 hover:-translate-y-0.5 hover:scale-110 active:scale-95"
            >
              <Icon name="lucide:globe" size={16} aria-hidden="true" />
            </a>
          )
        }
        {
          project.data.previewImage && (
            <div class="relative flex items-center justify-center" data-preview-wrapper>
              <button
                type="button"
                aria-label="Toggle preview screenshot"
                class="text-muted/60 group-hover:text-highlight/50 hover:text-highlight -m-2 flex cursor-pointer items-center justify-center p-2 transition-all duration-200 hover:-translate-y-0.5 hover:scale-110 focus:outline-none active:scale-95"
                data-preview-btn
              >
                <Icon name="lucide:image" size={16} aria-hidden="true" />
              </button>

              {/* Panel drops down from the header */}
              <div
                data-preview-panel
                class="pointer-events-none absolute top-full right-0 z-50 mt-2 w-64 origin-top-right translate-y-2 opacity-0 transition-all duration-200"
              >
                <div class="border-stroke overflow-hidden rounded-xl border shadow-2xl shadow-black/60">
                  <img
                    src={project.data.previewImage}
                    alt={`${project.data.title} preview`}
                    class="aspect-video w-full object-cover object-top"
                    loading="lazy"
                  />
                </div>
              </div>
            </div>
          )
        }
      </div>
    </div>

    <p class="text-body mt-3 text-sm leading-relaxed">{project.data.description}</p>
    {project.data.note && <p class="text-muted/70 mt-2 text-xs italic">{project.data.note}</p>}
  </div>

  {/* Extremely minimalist footer */}
  {
    primaryUrl && (
      <div class="border-stroke-subtle relative z-20 mt-6 flex justify-end border-t pt-4">
        <a
          href={primaryUrl}
          aria-label="Read project deep dive"
          class="text-muted group-hover:text-highlight/50 hover:text-highlight flex items-center gap-1.5 font-mono text-sm transition-colors duration-200 active:scale-95"
        >
          deep dive{' '}
          <Icon
            name="lucide:arrow-right"
            size={16}
            aria-hidden="true"
            class="transition-transform duration-300 group-hover:translate-x-1"
          />
        </a>
      </div>
    )
  }
</Card>

<script>
  // Add simple click-to-toggle logic for the preview panels
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    const btn = target.closest('[data-preview-btn]');

    const closeAll = () => {
      document.querySelectorAll('[data-preview-panel]').forEach((panel) => {
        panel.classList.add('opacity-0', 'translate-y-2', 'pointer-events-none');
        panel.classList.remove('opacity-100', 'translate-y-0', 'pointer-events-auto');
        const card = panel.closest('[data-scroll-reveal]') as HTMLElement | null;
        if (card) card.style.zIndex = '';
      });
    };

    // If clicking outside any preview panel, close them all
    if (!btn && !target.closest('[data-preview-panel]')) {
      closeAll();
      return;
    }

    // If clicking a button, toggle its specific panel
    if (btn) {
      const wrapper = btn.closest('[data-preview-wrapper]');
      const panel = wrapper?.querySelector('[data-preview-panel]');
      const card = btn.closest('[data-scroll-reveal]') as HTMLElement | null;
      if (!panel) return;

      const isHidden = panel.classList.contains('opacity-0');

      closeAll();

      if (isHidden) {
        panel.classList.remove('opacity-0', 'translate-y-2', 'pointer-events-none');
        panel.classList.add('opacity-100', 'translate-y-0', 'pointer-events-auto');
        if (card) card.style.zIndex = '100'; // Elevate the entire card above neighboring cards
      }
    }
  });
</script>

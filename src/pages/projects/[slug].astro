---
import { render } from 'astro:content';
import { getProjectNote, getProjectNotes } from '@entities/projectNote';
import { getProject } from '@entities/project';
import { BaseLayout, NotePageLayout } from '@shared/ui';

export async function getStaticPaths() {
  const notes = await getProjectNotes();
  return notes.map((note) => ({ params: { slug: note.id } }));
}

const { slug } = Astro.params;
const note = await getProjectNote(slug);
const project = await getProject(slug);

if (!note || !project) return Astro.redirect('/');

const { Content } = await render(note);
const { data } = project;
---

<BaseLayout title={`${data.title} — Deep Dive`}>
  <NotePageLayout backHref="/#projects" backLabel="Back to Projects">
    <Fragment slot="header">
      <div class="mb-3 flex items-center gap-3">
        <span class="font-mono text-xs uppercase tracking-widest text-highlight">
          {data.type ?? 'Project'}
        </span>
        <span class="font-mono text-xs text-muted/50">
          {data.startDate.toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}
        </span>
      </div>
      <h1 class="text-4xl font-bold tracking-tight text-primary">{data.title}</h1>
      <p class="mt-3 max-w-xl text-base leading-relaxed text-secondary">{data.description}</p>

      <div class="mt-6 flex items-center gap-4">
        {
          data.liveUrl && (
            <a
              href={data.liveUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="font-mono text-xs text-accent transition-colors duration-200 hover:text-highlight"
            >
              → {new URL(data.liveUrl).hostname}
            </a>
          )
        }
        {
          data.repoUrl && (
            <a
              href={data.repoUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="font-mono text-xs text-muted transition-colors duration-200 hover:text-highlight"
            >
              → github
            </a>
          )
        }
      </div>
    </Fragment>

    <Content />

    <Fragment slot="footer">
      <p class="mb-3 font-mono text-xs uppercase tracking-widest text-muted/50">Stack</p>
      <div class="flex flex-wrap gap-2">
        {
          data.tags.map((tag) => (
            <span class="rounded-md border border-stroke-subtle bg-surface-subtle px-2.5 py-1 font-mono text-xs text-muted">
              {tag}
            </span>
          ))
        }
      </div>
    </Fragment>
  </NotePageLayout>
</BaseLayout>

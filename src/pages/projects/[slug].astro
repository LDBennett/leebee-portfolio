---
import { render } from 'astro:content';
import { Image } from 'astro:assets';
import { getProjectNote, getProjectNotes } from '@entities/projectNote';
import { getProject } from '@entities/project';
import { BaseLayout, NotePageLayout, ScreenshotGallery } from '@shared/ui';

export async function getStaticPaths() {
  const notes = await getProjectNotes();
  return notes.map((note) => ({ params: { slug: note.id } }));
}

const { slug } = Astro.params;
const note = await getProjectNote(slug);
const project = await getProject(slug);

if (!note || !project) return Astro.redirect('/');

const { Content } = await render(note);
const { data } = project;

const statusColors: Record<string, string> = {
  'In Progress': 'text-warm border-warm/25 bg-warm/5',
  'Coming Soon': 'text-warm border-warm/25 bg-warm/5',
  'Active': 'text-highlight border-highlight/25 bg-highlight/5',
  'Completed': 'text-highlight border-highlight/25 bg-highlight/5',
  'Published': 'text-accent border-accent/25 bg-accent/5',
};
---

<BaseLayout title={`${data.title} — Deep Dive`}>
  <NotePageLayout backHref="/#projects" backLabel="Back to Projects">
    <Fragment slot="header">
      <div class="mb-3 flex items-center gap-3">
        <span class="text-highlight font-mono text-xs tracking-widest uppercase">
          {data.type ?? 'Project'}
        </span>
        {
          data.status && (
            <span
              class:list={[
                'rounded border px-1.5 py-0.5 font-mono text-[9px] font-semibold uppercase tracking-wider',
                statusColors[data.status] || 'text-muted border-stroke bg-surface-subtle',
              ]}
            >
              {data.status}
            </span>
          )
        }
        <span class="text-muted/50 font-mono text-xs">
          {data.startDate.toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}
        </span>
      </div>
      <h1 class="text-primary text-4xl font-bold tracking-tight">{data.title}</h1>

      <p class="text-secondary mt-4 max-w-xl text-base leading-relaxed">{data.description}</p>
      <div class="mt-4 flex flex-wrap gap-2">
        {
          data.tags.map((tag) => (
            <span class="border-stroke-subtle bg-surface-subtle text-muted rounded-md border px-2.5 py-1 font-mono text-xs">
              {tag}
            </span>
          ))
        }
      </div>
      <div class="mt-6 flex items-center gap-4">
        {
          data.liveUrl && (
            <a
              href={data.liveUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="text-accent hover:text-highlight font-mono text-xs transition-colors duration-200"
            >
              → {new URL(data.liveUrl).hostname}
            </a>
          )
        }
        {
          data.repoUrl && (
            <a
              href={data.repoUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="text-muted hover:text-highlight font-mono text-xs transition-colors duration-200"
            >
              → github
            </a>
          )
        }
      </div>
    </Fragment>

    <Content components={{ Image, ScreenshotGallery }} />
  </NotePageLayout>
</BaseLayout>

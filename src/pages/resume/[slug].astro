---
import { render } from 'astro:content';
import { getResumeNote, getResumeNotes } from '@entities/resumeNote';
import { getResumeEntry, formatDate } from '@entities/resume';
import { BaseLayout, NotePageLayout } from '@shared/ui';

export async function getStaticPaths() {
  const notes = await getResumeNotes();
  return notes.map((note) => ({ params: { slug: note.id } }));
}

const { slug } = Astro.params;
const note = await getResumeNote(slug);
const entry = await getResumeEntry(slug);

if (!note || !entry) return Astro.redirect('/');

const { Content } = await render(note);
const { data } = entry;
---

<BaseLayout title={`${data.role} at ${data.company}`}>
  <NotePageLayout backHref="/#resume" backLabel="Back to Experience">
    <Fragment slot="header">
      <div class="text-accent mb-1 font-mono text-xs tracking-widest uppercase">
        {formatDate(data.startDate)} – {data.endDate ? formatDate(data.endDate) : 'Present'}
      </div>
      <h1 class="text-primary text-4xl font-bold tracking-tight">{data.role}</h1>
      <p class="text-secondary mt-1 text-lg">{data.company}</p>
      {
        note.data.keyWins && note.data.keyWins.length > 0 && (
          <div class="mt-5 flex flex-wrap gap-2">
            {note.data.keyWins.map((win) => (
              <span class="border-highlight/30 bg-highlight/10 text-highlight rounded-full border px-3 py-1 font-mono text-xs">
                {win}
              </span>
            ))}
          </div>
        )
      }
      {
        data.description && (
          <p class="text-body mt-5 max-w-xl text-base leading-relaxed">{data.description}</p>
        )
      }
    </Fragment>

    <Content />

    <Fragment slot="footer">
      <p class="text-accent mb-6 font-mono text-xs tracking-widest uppercase">Tech</p>
      <div class="space-y-6">
        <div>
          <p class="text-muted/50 mb-3 font-mono text-xs tracking-widest uppercase">Worked With</p>
          <div class="flex flex-wrap gap-2">
            {data.tags.map((tag) => (
              <span class="border-stroke-subtle bg-surface-subtle text-muted rounded-md border px-2.5 py-1 font-mono text-xs">
                {tag}
              </span>
            ))}
          </div>
        </div>
        {note.data.introduced && note.data.introduced.length > 0 && (
          <div>
            <p class="text-muted/50 mb-3 font-mono text-xs tracking-widest uppercase">Introduced To</p>
            <div class="flex flex-wrap gap-2">
              {note.data.introduced.map((tag) => (
                <span class="border-accent/30 bg-accent/10 text-accent rounded-md border px-2.5 py-1 font-mono text-xs">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        )}
      </div>
    </Fragment>
  </NotePageLayout>
</BaseLayout>
